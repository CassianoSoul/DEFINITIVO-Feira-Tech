// JOGO 8: Sequência de Memória — grid 3x3, 5 rodadas, 3 tentativas
window.setupPuzzle8 = function() {
    digitar(txtEntidade, "Minha memória é perfeita. A sua? Observe a sequência que o sistema acende e repita na mesma ordem. Cinco rodadas e a barreira cede.");

    const FREQS         = [261, 294, 330, 349, 392, 440, 494, 523, 587];
    const TOTAL_RODADAS = 5;
    const MAX_ERROS     = 3;

    let sequencia = [], passo = 0, rodada = 0, bloqueado = true, erros = 0;

    const info = document.createElement('div');
    info.style.cssText = 'font-family:var(--font-mono);font-size:0.7rem;color:var(--text-dim);letter-spacing:2px;margin-bottom:12px;text-align:center;';
    info.textContent = 'iniciando em 3...';

    const grid = document.createElement('div');
    grid.className = 'memoria-grid';

    const cels = [];
    for (let i = 0; i < 9; i++) {
        const c = document.createElement('div');
        c.className = 'memoria-cel';
        c.textContent = i + 1;
        c._idx = i;
        cels.push(c);
        grid.appendChild(c);
    }

    const erroInfo = document.createElement('div');
    erroInfo.style.cssText = 'font-family:var(--font-mono);font-size:0.65rem;color:var(--text-dim);letter-spacing:1px;margin-top:8px;text-align:center;';
    erroInfo.textContent = 'tentativas restantes: ' + MAX_ERROS;

    const dica = document.createElement('div');
    dica.className = 'dica-empatica';
    dica.textContent = '// memorize a ordem exata das células que acendem';
    ativarDicaComDelay(dica);

    zonaInteracao.appendChild(info);
    zonaInteracao.appendChild(grid);
    zonaInteracao.appendChild(erroInfo);
    zonaInteracao.appendChild(dica);

    function acenderCel(idx, dur) {
        return new Promise(res => {
            AudioEngine.play(FREQS[idx], 0.32, 'sine', 0.04);
            cels[idx].classList.add('aceso');
            setTimeout(() => {
                cels[idx].classList.remove('aceso');
                setTimeout(res, 80);
            }, dur);
        });
    }

    async function exibirSequencia() {
        bloqueado = true;
        info.textContent = 'observe a sequência...';
        await new Promise(r => setTimeout(r, 600));
        for (let i = 0; i < sequencia.length; i++) {
            await acenderCel(sequencia[i], 500);
            await new Promise(r => setTimeout(r, 120));
        }
        passo = 0;
        bloqueado = false;
        info.textContent = 'sua vez — repita (' + sequencia.length + ' passos)';
    }

    function novaRodada() {
        sequencia.push(Math.floor(Math.random() * 9));
        rodada++;
        exibirSequencia();
    }

    function tratarErro(celClicada) {
        bloqueado = true;
        celClicada.classList.add('errado');
        AudioEngine.play(100, 0.4, 'sawtooth', 0.06);
        erros++;
        erroInfo.textContent = 'tentativas restantes: ' + (MAX_ERROS - erros);
        setTimeout(() => {
            celClicada.classList.remove('errado');
            if (erros >= MAX_ERROS) {
                registrarErro(MAX_ERROS);
            } else {
                sequencia = []; rodada = 0; passo = 0;
                info.textContent = 'errou. recomeçando do zero...';
                setTimeout(novaRodada, 900);
            }
        }, 700);
    }

    cels.forEach(c => {
        c.addEventListener('click', () => {
            if (bloqueado) return;
            const idx = c._idx;
            if (idx === sequencia[passo]) {
                bloqueado = true;
                acenderCel(idx, 280).then(() => {
                    passo++;
                    if (passo === sequencia.length) {
                        if (rodada >= TOTAL_RODADAS) {
                            info.textContent = 'memória confirmada.';
                            cels.forEach(c2 => c2.classList.add('certo'));
                            AudioEngine.play(800, 0.4, 'sine', 0.05);
                            setTimeout(proximoPuzzle, 800);
                        } else {
                            info.textContent = 'correto! próxima rodada...';
                            bloqueado = false;
                            setTimeout(novaRodada, 900);
                        }
                    } else {
                        bloqueado = false;
                    }
                });
            } else {
                tratarErro(c);
            }
        });
    });

    let conta = 3;
    const contagem = setInterval(() => {
        conta--;
        if (conta > 0) {
            info.textContent = 'iniciando em ' + conta + '...';
        } else {
            clearInterval(contagem);
            novaRodada();
        }
    }, 1000);
};

// JOGO 9: Fragmentação Binária — sequência aleatória a cada vez
window.setupPuzzle9 = function() {
    digitar(txtEntidade, "Altere os estilhaços lógicos até encontrar o alinhamento binário correto.");

    // Gera sequência aleatória de 4 bits que não seja 0000
    let alvo;
    do { alvo = Array.from({length: 4}, () => Math.floor(Math.random() * 2)); }
    while (alvo.join('') === '0000');
    const alvoStr = alvo.join('');

    const container = document.createElement('div');
    container.style.cssText = 'display:flex; gap:16px; align-items:center;';

    const val = [0, 0, 0, 0];
    const btns = [];

    const atualizarEstilo = (btn, v) => {
        btn.textContent = v;
        btn.style.fontSize = '1.6rem';
        btn.style.padding = '18px 28px';
        btn.style.borderColor = v === 1 ? 'var(--emocao-cor)' : '';
        btn.style.color = v === 1 ? 'var(--emocao-cor)' : '';
        btn.style.boxShadow = v === 1 ? '0 0 14px var(--emocao-bg)' : '';
    };

    for (let i = 0; i < 4; i++) {
        const btn = document.createElement('button');
        btn.className = 'btn-target';
        atualizarEstilo(btn, 0);
        btn.addEventListener('click', () => {
            val[i] = val[i] === 0 ? 1 : 0;
            atualizarEstilo(btn, val[i]);
            if (val.join('') === alvoStr) proximoPuzzle();
        });
        btns.push(btn);
        container.appendChild(btn);
    }

    const dica = document.createElement('div');
    dica.className = 'dica-empatica';
    dica.textContent = '// encontre a combinação binária correta';
    ativarDicaComDelay(dica);

    zonaInteracao.appendChild(container);
    zonaInteracao.appendChild(dica);
};

