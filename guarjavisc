    btnConfirmar.textContent = 'CONFIRMAR';
    btnConfirmar.style.opacity = '0.4';
    btnConfirmar.style.pointerEvents = 'none';

    const dica = document.createElement('div');
    dica.className = 'dica-empatica';
    dica.textContent = '// consulte a temperatura atual de Xique-Xique BA e insira aqui';

    ativarDicaComDelay(dica);
    zonaInteracao.appendChild(loading);
    zonaInteracao.appendChild(input);
    zonaInteracao.appendChild(btnConfirmar);
    zonaInteracao.appendChild(dica);

    const validar = () => {
        if (temperaturaReal === null) return;
        const valorDigitado = parseInt(input.value, 10);
        if (Math.abs(valorDigitado - temperaturaReal) <= 1) {
            AudioEngine.play(600, 0.2);
            proximoPuzzle();
        } else {
            registrarErro(1);
            input.value = '';
            alert('Flutuação térmica incorreta. Tente aproximar melhor a sensação local.');
        }
    };

    // Open-Meteo: gratuito, sem chave, coordenadas de Xique-Xique BA
    fetch('https://api.open-meteo.com/v1/forecast?latitude=-10.8228&longitude=-42.7275&current_weather=true')
        .then(r => r.json())
        .then(data => {
            temperaturaReal = Math.round(data.current_weather.temperature);
            loading.textContent = 'validador térmico pronto.';
            btnConfirmar.style.opacity = '1';
            btnConfirmar.style.pointerEvents = 'all';
        })
        .catch(() => {
            temperaturaReal = 32;
            loading.textContent = 'validador térmico pronto (modo offline).';
            btnConfirmar.style.opacity = '1';
            btnConfirmar.style.pointerEvents = 'all';
        });

    // Enter no input também confirma
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') validar(); });
    btnConfirmar.addEventListener('click', validar);
};

// JOGO 11: Dimensão Contraída
// Botão começa fora da tela à direita; Ctrl+Scroll o desliza para dentro.
window.setupPuzzle11 = function() {
    digitar(txtEntidade, "Minha existência transborda os limites que você enxerga. O botão de acesso existe além das bordas do que você vê agora. Contraia a realidade — encolha o mundo com Ctrl e o scroll do mouse até que o invisível se revele.");

    const instrucao = document.createElement('div');
    instrucao.style.cssText = 'font-family:var(--font-mono);font-size:0.72rem;color:var(--text-dim);letter-spacing:1px;text-align:center;line-height:2.2;';
    instrucao.innerHTML =
        'o botão está além da borda direita da tela' +
        '<br><span style="color:var(--text-mid)">[ Ctrl + scroll ↓ para revelar ]</span>' +
        '<br><span style="font-size:0.6rem;color:#2a2a2a">distância: <span id="p11-dist">máxima</span></span>';
    zonaInteracao.appendChild(instrucao);

    const dica = document.createElement('div');
    dica.className = 'dica-empatica';
    dica.textContent = '// segure Ctrl e role o scroll do mouse para baixo';
    ativarDicaComDelay(dica);
    zonaInteracao.appendChild(dica);

    const LARGURA_BTN = 180;
    const PASSO_PX    = 40;
    let posLeft = window.innerWidth + 80;

    const btn = document.createElement('button');
    btn.id = 'p11-btn';
    btn.className = 'btn-target';
    btn.textContent = 'ACESSAR NÚCLEO';
    btn.style.cssText = [
        'position:fixed',
        'top:50%',
        'margin-top:-20px',
        'left:' + posLeft + 'px',
        'z-index:999999',
        'white-space:nowrap',
        'pointer-events:auto',
        'transition:left 0.15s ease'
    ].join(';');
    document.body.appendChild(btn);

    btn.addEventListener('click', () => {
        limpar();
        AudioEngine.play(650, 0.15, 'sine', 0.04);
        proximoPuzzle();
    });

    function atualizar() {
        btn.style.left = posLeft + 'px';
        const lbl = document.getElementById('p11-dist');
        if (lbl) {
            const dist = posLeft - window.innerWidth;
            lbl.textContent = dist > 0
                ? Math.round(dist) + 'px além da borda'
                : 'visível';
            lbl.style.color = dist <= 0 ? 'var(--accent)' : '#2a2a2a';
        }
        AudioEngine.play(150 + Math.max(0, (window.innerWidth - posLeft) * 0.5), 0.03, 'sine', 0.02);
    }

    const onWheel = (e) => {
        if (!e.ctrlKey) return;
        e.preventDefault();
        if (e.deltaY > 0) {
            posLeft = Math.max(window.innerWidth - LARGURA_BTN - 40, posLeft - PASSO_PX);
        } else {
            posLeft = Math.min(window.innerWidth + 200, posLeft + PASSO_PX);
        }
        atualizar();
    };
    window.addEventListener('wheel', onWheel, { passive: false });

    function limpar() {
        window.removeEventListener('wheel', onWheel);
        const b = document.getElementById('p11-btn');
        if (b) b.remove();
    }

    const obs = new MutationObserver(() => {
        if (!zonaInteracao.contains(instrucao)) { limpar(); obs.disconnect(); }
    });
    obs.observe(zonaInteracao, { childList: true });
};

// JOGO 12: O PARADOXO DO ECO FINAL — 5 camadas
//
// CAMADA 1: sistema mostra SEQ1 (5 símbolos únicos) → jogador repete na ordem
// CAMADA 2: sistema mostra SEQ2 (nova sequência, com repetição) → jogador repete AO CONTRÁRIO
// CAMADA 3: 3 rodadas de 3 símbolos piscam rapidamente; 1 símbolo aparece nas 3 rodadas → jogador o identifica
// CAMADA 4: grade 5x5 embaralhada → clicar nos símbolos da SEQ1 em ordem, ignorando os distratores
// CAMADA 5: campo de texto → digitar SEQ1 + SEQ2 concatenados (sem espaço)
//
window.setupPuzzle12 = function() {
    digitar(txtEntidade, "Você chegou ao núcleo. Mas ele não se rende facilmente. Cinco camadas de verificação separam você do segredo. Observe. Memorize. Inverta. Encontre. Escreva.");

    const SIMBOLOS = ['◈', '⬡', '⟁', '◎', '⬢'];
    const CORES    = ['#ff2d2d', '#3de8ff', '#39ff85', '#ffb830', '#8844ff'];

    // SEQ1 — 5 símbolos únicos em ordem aleatória (camadas 1, 4 e 5)
    const SEQ1 = [0,1,2,3,4].sort(() => Math.random() - 0.5);

    // SEQ2 — 5 símbolos com repetição permitida, nova sequência (camadas 2 e 5)
    const SEQ2 = Array.from({length:5}, () => Math.floor(Math.random() * 5));

    let errosLocais = 0;

    // ── DOM base ─────────────────────────────────────────────────────────────
    const wrap = document.createElement('div');
    wrap.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:14px;width:100%;';
    zonaInteracao.appendChild(wrap);

    const infoFase = document.createElement('div');
    infoFase.style.cssText = 'font-family:var(--font-mono);font-size:0.6rem;color:var(--text-dim);letter-spacing:3px;text-transform:uppercase;text-align:center;';

    const info = document.createElement('div');
    info.style.cssText = 'font-family:var(--font-mono);font-size:0.72rem;color:var(--text-mid);letter-spacing:1px;text-align:center;min-height:1.4rem;';

    const display = document.createElement('div');
    display.style.cssText = 'display:flex;gap:14px;align-items:center;justify-content:center;min-height:72px;flex-wrap:wrap;';

    const botoesWrap = document.createElement('div');
    botoesWrap.style.cssText = 'display:flex;gap:10px;align-items:center;justify-content:center;flex-wrap:wrap;width:100%;';

    wrap.appendChild(infoFase);
    wrap.appendChild(display);
    wrap.appendChild(info);
    wrap.appendChild(botoesWrap);

    // ── utilidades ───────────────────────────────────────────────────────────
    const limparDisplay = () => { display.innerHTML = ''; };
    const limparBotoes  = () => { botoesWrap.innerHTML = ''; };

    function mostrarSimbolo(idx, dur) {
        return new Promise(res => {
            limparDisplay();
            const s = document.createElement('span');
            s.textContent = SIMBOLOS[idx];
            s.style.cssText = 'font-size:3.2rem;color:'+CORES[idx]+';text-shadow:0 0 28px '+CORES[idx]+';transition:opacity 0.12s;';
            display.appendChild(s);
            AudioEngine.play(260 + idx * 90, 0.22, 'sine', 0.04);
            setTimeout(() => { s.style.opacity = '0'; setTimeout(res, 110); }, dur);
        });
    }

    function mostrarErro(msg) {
        errosLocais++;
        info.style.color = 'var(--accent)';
        info.textContent = msg + '  [erro ' + errosLocais + ']';
        AudioEngine.play(90, 0.35, 'sawtooth', 0.06);
        setTimeout(() => { info.style.color = 'var(--text-mid)'; }, 1300);
    }

    function pulsar(btn, idx) {
        btn.style.boxShadow = '0 0 20px ' + CORES[idx];
        AudioEngine.play(260 + idx * 90, 0.12, 'sine', 0.03);
        setTimeout(() => { btn.style.boxShadow = ''; }, 320);
    }

    function criarBotoesSimbolos(onClickFn) {
        limparBotoes();
        for (let i = 0; i < 5; i++) {
            const btn = document.createElement('button');
            btn.className = 'btn-target';
            btn.textContent = SIMBOLOS[i];
            btn.style.cssText = 'font-size:1.5rem;padding:14px 18px;color:'+CORES[i]+';border-color:'+CORES[i]+'44;';
            btn.addEventListener('click', () => onClickFn(i, btn));
            botoesWrap.appendChild(btn);
        }
    }

    // ── CAMADA 1 ─────────────────────────────────────────────────────────────
    async function camada1() {
        limparBotoes(); limparDisplay();
        infoFase.textContent = '— camada 1 de 5 — sequência direta —';
        info.textContent = 'observe a sequência...';
        await new Promise(r => setTimeout(r, 800));

        for (const idx of SEQ1) {
            await mostrarSimbolo(idx, 520);
            await new Promise(r => setTimeout(r, 200));
        }
        limparDisplay();

        let passo = 0;
        info.textContent = 'repita na mesma ordem (' + SEQ1.length + ' símbolos)';

        criarBotoesSimbolos((i, btn) => {
            if (i === SEQ1[passo]) {
                pulsar(btn, i); passo++;
                info.textContent = 'correto... ' + passo + '/' + SEQ1.length;
                if (passo === SEQ1.length) {
                    info.textContent = 'camada 1 desbloqueada ✓';
                    limparBotoes();
                    setTimeout(camada2, 1100);
                }
            } else {
                mostrarErro('ordem errada — repita');
                passo = 0;
            }
        });
    }

    // ── CAMADA 2 ─────────────────────────────────────────────────────────────
    // Mostra SEQ2; jogador repete AO CONTRÁRIO
    async function camada2() {
        limparBotoes(); limparDisplay();
        infoFase.textContent = '— camada 2 de 5 — inversão —';
        info.textContent = 'observe esta nova sequência...';
        await new Promise(r => setTimeout(r, 800));

        for (const idx of SEQ2) {
            await mostrarSimbolo(idx, 520);
            await new Promise(r => setTimeout(r, 200));
        }
        limparDisplay();

        const invertida = [...SEQ2].reverse();
        let passo = 0;
        info.textContent = 'agora repita AO CONTRÁRIO (' + invertida.length + ' símbolos)';

        const tentativa = () => {
            limparBotoes();
            passo = 0;
            criarBotoesSimbolos((i, btn) => {
                if (i === invertida[passo]) {
                    pulsar(btn, i); passo++;
                    info.textContent = 'correto... ' + passo + '/' + invertida.length;
                    if (passo === invertida.length) {
                        info.textContent = 'camada 2 desbloqueada ✓';
                        limparBotoes();
                        setTimeout(camada3, 1100);
                    }
                } else {
                    mostrarErro('ordem errada — observe novamente');
                    limparBotoes();
                    setTimeout(async () => {
                        info.textContent = 'observe novamente...';
                        await new Promise(r => setTimeout(r, 600));
                        for (const idx of SEQ2) {
                            await mostrarSimbolo(idx, 520);
                            await new Promise(r => setTimeout(r, 200));
                        }
                        limparDisplay();
                        info.textContent = 'repita AO CONTRÁRIO';
                        tentativa();
                    }, 900);
                }
            });
        };
        tentativa();
    }

    // ── CAMADA 3 ─────────────────────────────────────────────────────────────
    // 3 rodadas de 3 símbolos piscam; 1 símbolo está em todas as rodadas
    async function camada3() {
        limparBotoes(); limparDisplay();
        infoFase.textContent = '— camada 3 de 5 — interseção —';
        info.textContent = 'três sequências vão aparecer. um símbolo estará em todas.';
        await new Promise(r => setTimeout(r, 1500));

        const comum = Math.floor(Math.random() * 5);
        const rounds = [];
        for (let r = 0; r < 3; r++) {
            const outros = [0,1,2,3,4].filter(x => x !== comum).sort(() => Math.random() - 0.5).slice(0, 2);
            rounds.push([...outros, comum].sort(() => Math.random() - 0.5));
        }

        for (let r = 0; r < 3; r++) {
            info.textContent = 'sequência ' + (r+1) + ' de 3...';
            await new Promise(re => setTimeout(re, 600));
            for (const idx of rounds[r]) {
                await mostrarSimbolo(idx, 400);
                await new Promise(re => setTimeout(re, 150));
            }
            limparDisplay();
            if (r < 2) {
                info.textContent = 'próxima em 1s...';
                await new Promise(re => setTimeout(re, 900));
            }
        }

        info.textContent = 'qual símbolo apareceu nas 3 sequências?';
        criarBotoesSimbolos((i, btn) => {
            if (i === comum) {
                pulsar(btn, i);
                info.textContent = 'camada 3 desbloqueada ✓';
                limparBotoes();
                setTimeout(camada4, 1100);
            } else {
                mostrarErro('não é esse — tente novamente');
            }
        });
    }

    // ── CAMADA 4 ─────────────────────────────────────────────────────────────
    // Grade 5x5 embaralhada; clicar só nos da SEQ1 em ordem
    function camada4() {
        limparBotoes(); limparDisplay();
        infoFase.textContent = '— camada 4 de 5 — grade de extração —';
        info.textContent = 'encontre os símbolos da PRIMEIRA sequência na ordem certa';

        // 5 células corretas (SEQ1) + 20 distratores
        const celulas = SEQ1.map(idx => ({ idx, real: true }));
        while (celulas.length < 25) celulas.push({ idx: Math.floor(Math.random() * 5), real: false });
        celulas.sort(() => Math.random() - 0.5);

        const grade = document.createElement('div');
        grade.style.cssText = 'display:grid;grid-template-columns:repeat(5,1fr);gap:6px;width:100%;max-width:300px;';

        let passo = 0;
        celulas.forEach(cel => {
            const btn = document.createElement('button');
            btn.className = 'btn-target';
            btn.textContent = SIMBOLOS[cel.idx];
            btn.style.cssText = 'font-size:1.1rem;padding:10px 4px;color:'+CORES[cel.idx]+';border-color:'+CORES[cel.idx]+'33;';
            btn.addEventListener('click', () => {
                if (btn.disabled) return;
                if (cel.real && cel.idx === SEQ1[passo]) {
                    pulsar(btn, cel.idx);
                    btn.style.opacity = '0.25';
                    btn.disabled = true;
                    passo++;
                    info.textContent = passo + '/' + SEQ1.length + ' encontrados';
                    if (passo === SEQ1.length) {
                        info.textContent = 'camada 4 desbloqueada ✓';
                        setTimeout(camada5, 1100);
                    }
                } else {
                    mostrarErro('errado ou fora de ordem — recomeçando grade');
                    grade.querySelectorAll('button').forEach(b => { b.style.opacity = '1'; b.disabled = false; });
                    passo = 0;
                }
            });
            grade.appendChild(btn);
        });

        limparBotoes();
        botoesWrap.appendChild(grade);
    }

    // ── CAMADA 5 ─────────────────────────────────────────────────────────────
    // Digitar SEQ1 + SEQ2 concatenados
    function camada5() {
        limparBotoes(); limparDisplay();
        infoFase.textContent = '— camada 5 de 5 — código final —';

        const respostaFinal = SEQ1.map(i => SIMBOLOS[i]).join('') + SEQ2.map(i => SIMBOLOS[i]).join('');

        const label = document.createElement('div');
        label.style.cssText = 'font-family:var(--font-mono);font-size:0.62rem;color:var(--text-dim);letter-spacing:2px;text-align:center;line-height:2;';
        label.innerHTML = 'combine: <span style="color:#39ff85">sequência 1</span> + <span style="color:#3de8ff">sequência 2</span> (sem espaço)';

        // referência clicável: SEQ1 | SEQ2
        const ref = document.createElement('div');
        ref.style.cssText = 'display:flex;gap:6px;font-size:1.3rem;justify-content:center;flex-wrap:wrap;margin:4px 0;align-items:center;';
        [...SEQ1, ...SEQ2].forEach((idx, pos) => {
            if (pos === 5) {
                const sep = document.createElement('span');
                sep.textContent = '|';
                sep.style.cssText = 'color:#333;font-size:1rem;';
                ref.appendChild(sep);
            }
            const s = document.createElement('span');
            s.textContent = SIMBOLOS[idx];
            s.style.cssText = 'color:'+CORES[idx]+';cursor:pointer;user-select:none;opacity:'+(pos<5?'1':'0.6')+';';
            s.title = 'clique para inserir';
            s.addEventListener('click', () => { inputFinal.value += SIMBOLOS[idx]; });
            ref.appendChild(s);
        });

        const inputFinal = document.createElement('input');
        inputFinal.className = 'input-custom';
        inputFinal.placeholder = 'clique nos símbolos ou cole aqui';
        inputFinal.style.userSelect = 'text';
        inputFinal.style.pointerEvents = 'all';
        inputFinal.style.fontSize = '1.2rem';
        inputFinal.style.letterSpacing = '4px';

        const btnOk = document.createElement('button');
        btnOk.className = 'btn-target';
        btnOk.textContent = 'VERIFICAR CÓDIGO FINAL';

        const validar = () => {
            if (inputFinal.value.trim() === respostaFinal) {
                info.textContent = 'núcleo desbloqueado.';
                limparBotoes();
                limparDisplay();
                let j = 0;
                const todos = [...SEQ1, ...SEQ2];
                const celebrar = setInterval(() => {
                    if (j >= todos.length) { clearInterval(celebrar); setTimeout(abrirPortal, 700); return; }
                    const s = document.createElement('span');
                    s.textContent = SIMBOLOS[todos[j]];
                    s.style.cssText = 'font-size:2rem;color:'+CORES[todos[j]]+';text-shadow:0 0 24px '+CORES[todos[j]]+';margin:0 4px;';
                    display.appendChild(s);
                    AudioEngine.play(300 + todos[j] * 80, 0.15, 'sine', 0.04);
                    j++;
                }, 130);
            } else {
                mostrarErro('código incorreto');
                inputFinal.value = '';
            }
        };

        inputFinal.addEventListener('keydown', e => { if (e.key === 'Enter') validar(); });
        btnOk.addEventListener('click', validar);

        botoesWrap.appendChild(label);
        botoesWrap.appendChild(ref);
        botoesWrap.appendChild(inputFinal);
        botoesWrap.appendChild(btnOk);
        info.textContent = 'insira o código combinado das duas sequências';
    }

    // ── PORTAL: flash branco longo → segredo.html ────────────────────────────
    function abrirPortal() {
        const flash = document.createElement('div');
        flash.style.cssText = 'position:fixed;inset:0;background:#fff;z-index:999999;opacity:0;pointer-events:none;transition:opacity 0.5s ease;';
        document.body.appendChild(flash);
        AudioEngine.play(1200, 2.5, 'sine', 0.09);
        requestAnimationFrame(() => {
            requestAnimationFrame(() => { flash.style.opacity = '1'; });
        });
        // fica branco por 3s antes de redirecionar
        setTimeout(() => { window.location.href = 'segredo.html'; }, 3200);
    }

    // inicia
    camada1();
};

